# Docker Compose reads this file automatically when copied to server/.env.
# For cargo run, source ../.hamlet-worktree.env or export HAMLET_BIND_ADDR.
# Some variables in this file are controlled directly by Docker Compose,
# or have defaults there if not set here. Check docker-compose.yml if you're wondering
# why a change here didn't affect the app.
HAMLET_SERVER_PORT=3030
HAMLET_BIND_ADDR=127.0.0.1:3030
RUST_LOG=info

# Production web/API hosting. For a hosted static client, set exact origins,
# comma-separated, for credentialed browser requests.
HAMLET_ALLOWED_ORIGINS=
# For HTTPS cross-site cookies use: HAMLET_COOKIE_SECURE=true and HAMLET_COOKIE_SAME_SITE=none.
HAMLET_COOKIE_SECURE=false
HAMLET_COOKIE_SAME_SITE=lax

# Keep public production registration disabled and provision users with hamlet-admin.
HAMLET_ACCOUNT_REGISTRATION_ENABLED=false
# Optional server-side Sentry DSN. Leave blank to disable.
HAMLET_SENTRY_DSN=

# Docker Compose stores the DB and uploads in the hamlet_data volume at /var/lib/hamlet.
# For local cargo run, leave HAMLET_DATA_DIR unset to use the platform app-data dir.
# HAMLET_DATA_DIR=./data
# TODO(reno): These settings for DB stuff seem...a little odd. Probably worth a refactor.
# HAMLET_DATABASE_URL overrides HAMLET_DATA_DIR completely. Use a file URL for persistence.
# HAMLET_DATABASE_URL=sqlite://data/hamlet.db?mode=rwc
# For a clean-room run that resets on process exit, use a named in-memory URL.
# HAMLET_DATABASE_URL=sqlite:file:hamlet_clean_room?mode=memory&cache=shared
HAMLET_UPLOADS_DIR=./uploads
HAMLET_MESSAGE_ATTACHMENTS_DIR=./private-uploads/message-attachments
# Bootstraps general + voice only when the channel table is empty.
HAMLET_BOOTSTRAP_DEFAULT_CHANNELS=true
# Debug builds default this to true; release builds default it to false.
# Set false for release-shaped local runs without baipas/teo dev users.
# HAMLET_SEED_DEV_DATA=true

# Voice/video is optional. Leave all three empty to disable voice endpoints in production.
# The dev Compose override supplies local LiveKit defaults (devkey/devsecret) when these are unset.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Self-hosted production LiveKit config path used by docker-compose.livekit.yml.
# HAMLET_LIVEKIT_CONFIG=./livekit.prod.yaml
HAMLET_LIVEKIT_PORT=7880
HAMLET_LIVEKIT_TCP_PORT=7881
HAMLET_LIVEKIT_UDP_START=50000
HAMLET_LIVEKIT_UDP_END=50100
