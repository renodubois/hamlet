# Docker Compose reads this file automatically when copied to server/.env.
# For cargo run, source ../.hamlet-worktree.env or export HAMLET_BIND_ADDR.
HAMLET_SERVER_PORT=3030
HAMLET_BIND_ADDR=127.0.0.1:3030
# Docker Compose stores the DB and uploads in the hamlet_data volume at /var/lib/hamlet.
# For local cargo run, leave HAMLET_DATA_DIR unset to use the platform app-data dir.
# HAMLET_DATA_DIR=./data
# DATABASE_URL overrides HAMLET_DATA_DIR completely. Use a file URL for persistence.
# DATABASE_URL=sqlite://data/hamlet.db?mode=rwc
# For a clean-room run that resets on process exit, use a named in-memory URL.
# DATABASE_URL=sqlite:file:hamlet_clean_room?mode=memory&cache=shared
HAMLET_UPLOADS_DIR=./uploads
HAMLET_MESSAGE_ATTACHMENTS_DIR=./private-uploads/message-attachments
# Bootstraps general + voice only when the channel table is empty.
HAMLET_BOOTSTRAP_DEFAULT_CHANNELS=true
# Debug builds default this to true; release builds default it to false.
# Set false for release-shaped local runs without baipas/teo dev users.
# HAMLET_SEED_DEV_DATA=true
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret
HAMLET_LIVEKIT_PORT=7880
HAMLET_LIVEKIT_TCP_PORT=7881
HAMLET_LIVEKIT_UDP_START=50000
HAMLET_LIVEKIT_UDP_END=50100
HAMLET_LIVEKIT_CONFIG=./livekit.local.yaml
