{
  "name": "client",
  "version": "0.1.0",
  "description": "Hamlet Electron alpha client",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "pnpm run build:renderer && pnpm run electron:build",
    "build:renderer": "vite build",
    "build:web": "vite build && node scripts/prepare-web-dist.mjs",
    "serve": "vite preview",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "electron:build": "node scripts/build-electron.mjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:typecheck": "tsc -p tsconfig.electron.json --noEmit",
    "package:unpacked": "pnpm run build && node scripts/package-unpacked.mjs",
    "package:launch": "pnpm run package:unpacked && node scripts/launch-unpacked.mjs",
    "package:smoke": "pnpm run package:unpacked && playwright test -c playwright.package.config.ts",
    "package:full": "node scripts/package-full-deferred.mjs package:full",
    "lint": "oxlint -c oxlint.config.json . --format stylish",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit && pnpm run electron:typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm run test:e2e:renderer && pnpm run test:e2e:electron",
    "test:e2e:renderer": "playwright test -c playwright.config.ts",
    "test:e2e:voice:browser": "node scripts/test-browser-voice.mjs",
    "test:e2e:electron": "pnpm run build && playwright test -c playwright.electron.config.ts",
    "size": "pnpm run build && size-limit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@sentry/react": "^10.64.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cropperjs": "^2.1.1",
    "jdenticon": "^3.3.0",
    "livekit-client": "^2.18.3",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.11.3",
    "electron": "^42.1.0",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.9.0",
    "msw": "^2.13.4",
    "msw-storybook-addon": "^2.0.7",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.24.0",
    "postcss": "^8.4.49",
    "size-limit": "^12.1.0",
    "storybook": "^10.5.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0"
  },
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=11.11.0"
  },
  "packageManager": "pnpm@11.11.0",
  "msw": {
    "workerDirectory": [
      ".storybook/public"
    ]
  },
  "productName": "Hamlet Electron Alpha"
}
