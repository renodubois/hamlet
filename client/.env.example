# Optional per-worktree renderer and API defaults.
# npm run dev / serve read these through Vite; npm run electron:dev also loads
# .env.local before launching Electron.
HAMLET_RENDERER_HOST=127.0.0.1
HAMLET_RENDERER_PORT=1422
VITE_HAMLET_DEFAULT_SERVER_URL=http://127.0.0.1:3030
# Optional renderer-side Sentry DSN. Leave unset or empty to disable client telemetry.
VITE_HAMLET_SENTRY_DSN=
